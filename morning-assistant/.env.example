# =========================================================
#  Morning Assistant 環境変数サンプル
#  cp .env.example .env でコピー（.env は .gitignore 済み）
#
#  ★ 既定は「完全無料スタック」。この .env が無くてもそのまま動きます。
#     天気=open-meteo / カレンダー=local / 台本=template / 音声=say(macOS)
#     → APIキー・登録・課金いっさい不要。
#
#  必要に応じて下の PROVIDER を変えると有料/高機能版に切り替わります。
# =========================================================

# ---------- 呼びかけ名 ----------
USER_NICKNAME=たくちゃん

# ---------- 天気 ----------
# open-meteo（キー不要・無料／既定） か openweathermap（要キー）
WEATHER_PROVIDER=open-meteo
WEATHER_CITY_NAME=横浜
WEATHER_LAT=35.4437
WEATHER_LON=139.6380
# openweathermap を使う場合のみ
# OPENWEATHER_API_KEY=your_key_here

# ---------- カレンダー ----------
# local（schedule.json・設定不要／既定） か google（要OAuth）
CALENDAR_PROVIDER=local
SCHEDULE_FILE=schedule.json
# google を使う場合のみ
# GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_TOKEN_FILE=token.json

# ---------- 台本生成（LLM） ----------
# template（課金なし／既定）/ ollama（ローカルLLM・無料）/ anthropic / openai
LLM_PROVIDER=template
# ollama を使う場合のみ
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1
# anthropic / openai を使う場合のみ
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# ---------- 音声合成（TTS） ----------
# say（macOS標準・無料／既定）/ openai / elevenlabs
TTS_PROVIDER=say
SAY_VOICE=Kyoko
SAY_RATE=180
# openai TTS を使う場合のみ（OPENAI_API_KEY も必要）
# OPENAI_TTS_VOICE=alloy
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# elevenlabs を使う場合のみ
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here
