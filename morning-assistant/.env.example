# =========================================================
#  Morning Assistant 環境変数サンプル
#  このファイルを .env という名前でコピーして値を埋めてください:
#    cp .env.example .env
#  .env は .gitignore 済みなので、絶対にコミットされません。
# =========================================================

# ---------- 天気 (OpenWeatherMap) ----------
# https://openweathermap.org/ で無料登録して取得
OPENWEATHER_API_KEY=your_openweather_api_key_here
# 対象地域（デフォルト: 神奈川県横浜市）。緯度経度で指定します。
WEATHER_CITY_NAME=横浜
WEATHER_LAT=35.4437
WEATHER_LON=139.6380

# ---------- 台本生成 (LLM) ----------
# LLM_PROVIDER は "anthropic" か "openai" のどちらか
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ---------- 音声合成 (TTS) ----------
# TTS_PROVIDER は "openai" か "elevenlabs" のどちらか
TTS_PROVIDER=openai
# OpenAI TTS を使う場合は上の OPENAI_API_KEY を利用します。
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# ElevenLabs を使う場合のみ
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# ---------- 呼びかけ設定 ----------
# 台本内での呼びかけ名（例: たくちゃん）
USER_NICKNAME=たくちゃん

# ---------- Google Calendar ----------
# OAuth クライアント情報の JSON ファイルパス（後述の手順で取得）
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
